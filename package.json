{
  "name": "hujson",
  "displayName": "HuJSON - Human JSON",
  "description": "Syntax highlighting for HuJSON (JWCC) - JSON with comments and trailing commas",
  "version": "1.1.0",
  "publisher": "armstrongl",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/armstrongl/vscode-hujson"
  },
  "homepage": "https://github.com/armstrongl/vscode-hujson",
  "bugs": {
    "url": "https://github.com/armstrongl/vscode-hujson/issues"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "hujson",
    "jwcc",
    "json",
    "comments",
    "trailing commas"
  ],
  "contributes": {
    "languages": [
      {
        "id": "hujson",
        "aliases": [
          "HuJSON",
          "JWCC",
          "Human JSON",
          "JSON with Commas and Comments"
        ],
        "extensions": [
          ".hujson",
          ".jwcc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hujson",
        "scopeName": "source.hujson",
        "path": "./hujson.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[hujson]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.formatOnSave": false
      }
    },
    "snippets": [
      {
        "language": "hujson",
        "path": "./snippets/hujson.json"
      }
    ]
  }
}